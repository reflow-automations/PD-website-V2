---
import Logo from './Logo.astro';
import BookTrialButton from './BookTrialButton.astro';
import { NAV, EXTERNAL } from '../consts';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class="hdr" data-header>
  <div class="hdr__inner container--wide">
    <Logo class="hdr__logo" />

    <nav class="hdr__nav" aria-label="Hoofdmenu">
      {NAV.map((item) => (
        <a href={item.href} class:list={['hdr__link', isActive(item.href) && 'is-active']}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hdr__right">
      <a href={EXTERNAL.login} class="hdr__login" rel="noopener" target="_blank">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="18" height="18">
          <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM5 20a7 7 0 0 1 14 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
        </svg>
        <span>Inloggen</span>
      </a>
      <span class="hdr__cta"><BookTrialButton size="md" /></span>
      <button class="hdr__burger" data-burger type="button" aria-label="Menu openen" aria-expanded="false" aria-controls="mobile-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="hdr__mobile" id="mobile-nav" data-mobile aria-hidden="true">
    <nav class="hdr__mobile-nav" aria-label="Mobiel menu">
      {NAV.map((item, i) => (
        <a href={item.href} class:list={['hdr__mobile-link', isActive(item.href) && 'is-active']} style={`--i:${i}`}>
          <span>{item.label}</span>
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="20" height="20"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
        </a>
      ))}
    </nav>
    <div class="hdr__mobile-foot">
      <a href={EXTERNAL.login} class="hdr__mobile-login" rel="noopener" target="_blank">Inloggen leden</a>
      <BookTrialButton size="lg" />
    </div>
  </div>

<style>
  .hdr {
    position: fixed; inset: 0 0 auto 0; z-index: 100;
    transition: background 0.3s var(--ease), box-shadow 0.3s, border-color 0.3s;
    border-bottom: 1px solid transparent;
  }
  .hdr::before {
    content: ""; position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(to bottom, rgba(11, 18, 32, 0.78), rgba(11, 18, 32, 0));
    opacity: 1; transition: opacity 0.3s;
  }
  .hdr.is-scrolled { background: rgba(11, 18, 32, 0.92); backdrop-filter: blur(10px); border-bottom-color: var(--line-dark); box-shadow: 0 10px 30px -20px rgba(0, 0, 0, 0.8); }
  .hdr.is-scrolled::before { opacity: 0; }

  .hdr__inner { display: flex; align-items: center; gap: 1.5rem; min-height: 5rem; }
  .hdr__nav { display: none; align-items: center; gap: clamp(0.55rem, 1.1vw, 1.2rem); margin-inline: auto; }
  .hdr__link {
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.78rem;
    color: var(--on-dark-soft); padding: 0.4rem 0; position: relative; white-space: nowrap;
  }
  .hdr__link::after {
    content: ""; position: absolute; left: 0; bottom: -2px; height: 2px; width: 100%;
    background: var(--red); transform: scaleX(0); transform-origin: left; transition: transform 0.28s var(--ease);
  }
  .hdr__link:hover { color: #fff; }
  .hdr__link:hover::after, .hdr__link.is-active::after { transform: scaleX(1); }
  .hdr__link.is-active { color: #fff; }

  .hdr__right { display: flex; align-items: center; gap: 0.9rem; margin-left: auto; }
  .hdr__login {
    display: none; align-items: center; gap: 0.45rem; color: var(--on-dark-soft);
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.78rem;
  }
  .hdr__login:hover { color: #fff; }

  /* Burger */
  .hdr__burger { display: inline-flex; flex-direction: column; justify-content: center; gap: 5px; width: 2.75rem; height: 2.75rem; padding: 0 0.6rem; }
  .hdr__burger span { height: 2.5px; width: 100%; background: #fff; border-radius: 2px; transition: transform 0.3s var(--ease), opacity 0.2s; }
  .hdr.is-open .hdr__burger span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
  .hdr.is-open .hdr__burger span:nth-child(2) { opacity: 0; }
  .hdr.is-open .hdr__burger span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }

  /* Mobile panel */
  .hdr__mobile {
    position: fixed; inset: 0; z-index: 99; height: 100dvh;
    background: var(--ink);
    padding: 5.25rem var(--gutter) 2.5rem; display: flex; flex-direction: column;
    transform: translateY(-10px); opacity: 0; pointer-events: none;
    transition: transform 0.35s var(--ease), opacity 0.3s; overflow-y: auto;
  }
  .hdr__mobile.is-open { transform: none; opacity: 1; pointer-events: auto; }
  .hdr__mobile-nav { display: flex; flex-direction: column; }
  .hdr__mobile-link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.05rem 0; border-bottom: 1px solid var(--line-dark);
    font-family: var(--font-display); text-transform: uppercase; font-size: 1.75rem; color: #fff;
  }
  .hdr__mobile-link svg { color: var(--on-dark-faint); transition: color 0.2s, transform 0.2s; }
  .hdr__mobile-link.is-active { color: var(--red); }
  .hdr__mobile-link.is-active svg, .hdr__mobile-link:hover svg { color: var(--red); transform: translateX(4px); }
  .hdr__mobile-foot { margin-top: 1.8rem; display: flex; flex-direction: column; gap: 1rem; }
  .hdr__mobile-login { color: var(--on-dark-soft); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.85rem; }

  @media (min-width: 1240px) {
    .hdr__nav { display: flex; }
    .hdr__login { display: inline-flex; }
    .hdr__burger { display: none; }
    .hdr__mobile { display: none; }
  }
  @media (max-width: 440px) {
    .hdr__inner { gap: 0.55rem; min-height: 4.5rem; }
    .hdr__cta :global(.btn) { padding: 0.6rem 0.85rem; font-size: 0.68rem; letter-spacing: 0.03em; gap: 0.4em; }
    .hdr__burger { width: 2.4rem; padding: 0 0.4rem; }
  }
</style>

<script>
  const header = document.querySelector('[data-header]');
  const burger = document.querySelector('[data-burger]');
  const mobile = document.querySelector('[data-mobile]');

  // Sticky/solid on scroll
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle('is-scrolled', window.scrollY > 8);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile menu toggle
  const setOpen = (open: boolean) => {
    header?.classList.toggle('is-open', open);
    mobile?.classList.toggle('is-open', open);
    burger?.setAttribute('aria-expanded', String(open));
    burger?.setAttribute('aria-label', open ? 'Menu sluiten' : 'Menu openen');
    mobile?.setAttribute('aria-hidden', String(!open));
    document.body.style.overflow = open ? 'hidden' : '';
  };
  burger?.addEventListener('click', () => setOpen(!header?.classList.contains('is-open')));
  mobile?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });
  // Close menu if resizing up to desktop
  window.matchMedia('(min-width: 1240px)').addEventListener('change', (e) => { if (e.matches) setOpen(false); });
</script>
