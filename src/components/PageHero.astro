---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
}
const { eyebrow, title, intro } = Astro.props;
---

<section class="phero noise">
  <span class="phero__ghost" aria-hidden="true">PD</span>
  <div class="container">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="phero__title">{title}</h1>
    {intro && <p class="phero__intro lead">{intro}</p>}
    <slot />
  </div>
</section>

<style>
  .phero {
    position: relative; overflow: hidden; isolation: isolate;
    padding-top: clamp(7.5rem, 13vh, 10.5rem);
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
    border-bottom: 1px solid var(--line-dark);
  }
  .phero__ghost {
    position: absolute; top: 50%; right: -0.05em; transform: translateY(-42%);
    font-family: var(--font-display); font-size: 34vw; line-height: 0.7; color: #fff;
    opacity: 0.03; z-index: -1; pointer-events: none;
  }
  .phero__title { font-size: clamp(2.6rem, 7vw, 6rem); margin-top: 1rem; line-height: 0.88; }
  .phero__intro { margin-top: 1.3rem; max-width: 50ch; }
</style>
