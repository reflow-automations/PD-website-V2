---
import Logo from './Logo.astro';
import { SITE, CONTACT, EXTERNAL, FOOTER_LINKS } from '../consts';

const year = 2026;

const locations = [
  { name: 'Hero Academy', city: 'Alphen a/d Rijn' },
  { name: 'Gymworld Freerun Academy', city: 'Zoetermeer' },
  { name: 'Roots Academy', city: 'Zoetermeer' },
  { name: 'Play Freerun Academy', city: 'Leiden' },
  { name: 'Silver Academy', city: 'Krimpenerwaard' },
  { name: 'Locatie Nijmegen', city: 'Nijmegen' },
];

const socials = [
  { label: 'Instagram', href: EXTERNAL.instagram, d: 'M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s0 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38c-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.2 15.58 2.2 15.2 2.2 12s0-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.2 8.8 2.2 12 2.2Zm0 3.05A6.75 6.75 0 1 0 18.75 12 6.75 6.75 0 0 0 12 5.25Zm0 11.14A4.39 4.39 0 1 1 16.39 12 4.39 4.39 0 0 1 12 16.39Zm6.99-11.43a1.58 1.58 0 1 1-1.58-1.57 1.58 1.58 0 0 1 1.58 1.57Z' },
  { label: 'Facebook', href: EXTERNAL.facebook, d: 'M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.45 2.89h-2.33v6.99A10 10 0 0 0 22 12Z' },
  { label: 'YouTube', href: EXTERNAL.youtube, d: 'M23.5 6.5a3 3 0 0 0-2.1-2.13C19.5 3.85 12 3.85 12 3.85s-7.5 0-9.4.52A3 3 0 0 0 .5 6.5 31.2 31.2 0 0 0 0 12a31.2 31.2 0 0 0 .5 5.5 3 3 0 0 0 2.1 2.13c1.9.52 9.4.52 9.4.52s7.5 0 9.4-.52a3 3 0 0 0 2.1-2.13A31.2 31.2 0 0 0 24 12a31.2 31.2 0 0 0-.5-5.5ZM9.6 15.57V8.43L15.8 12Z' },
];
---

<footer class="ft section--ink">
  <div class="container--wide">
    <div class="ft__top">
      <div class="ft__brand">
        <Logo />
        <p class="ft__claim">De leukste Parkour &amp; Freerunning school van Nederland <span aria-hidden="true">🇳🇱</span></p>
        <div class="ft__contact">
          <a href={CONTACT.phoneHref} class="ft__phone">{CONTACT.phone}</a>
          <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
        </div>
        <div class="ft__social">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} class="ft__soc">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="20" height="20"><path d={s.d}></path></svg>
            </a>
          ))}
        </div>
        <div class="ft__apps">
          <a href={EXTERNAL.appApple} target="_blank" rel="noopener" class="ft__app">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M16.4 12.7c0-2.2 1.8-3.3 1.9-3.3-1-1.5-2.6-1.7-3.2-1.7-1.4-.1-2.6.8-3.3.8-.7 0-1.7-.8-2.8-.8-1.5 0-2.8.8-3.6 2.1-1.5 2.7-.4 6.6 1.1 8.8.7 1 1.5 2.2 2.6 2.2 1 0 1.4-.7 2.7-.7s1.6.7 2.7.7c1.1 0 1.8-1.1 2.5-2.1.8-1.2 1.1-2.3 1.1-2.4 0 0-2.1-.8-2.1-3.1Zm-2.2-5.7c.6-.7 1-1.7.9-2.7-.9 0-1.9.6-2.5 1.3-.5.6-1 1.6-.9 2.6 1 .1 1.9-.5 2.5-1.2Z"></path></svg>
            <span><small>Download in de</small>App Store</span>
          </a>
          <a href={EXTERNAL.appGoogle} target="_blank" rel="noopener" class="ft__app">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M3.6 2.3 13 11.7l-2.6 2.6L3.2 3.1c.1-.3.2-.6.4-.8Zm-.4 19.4L10.4 14l2.6 2.6-9.4 5.4c-.2-.1-.3-.2-.4-.3Zm12.2-7 2.7-1.6c.9-.5.9-1.6 0-2.1l-2.7-1.6L13 12l2.4 2.7Z"></path></svg>
            <span><small>Ontdek het op</small>Google Play</span>
          </a>
        </div>
      </div>

      <nav class="ft__cols" aria-label="Footer">
        <div class="ft__col">
          <h2 class="ft__h">Ontdek</h2>
          <ul role="list">
            {FOOTER_LINKS.ontdek.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
          </ul>
        </div>
        <div class="ft__col">
          <h2 class="ft__h">Aanbod</h2>
          <ul role="list">
            {FOOTER_LINKS.aanbod.map((l: any) => (
              <li><a href={l.href} {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}>{l.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="ft__col">
          <h2 class="ft__h">Locaties</h2>
          <ul role="list">
            {locations.map((l) => (
              <li><a href="/locaties/">{l.name} <span class="ft__city">· {l.city}</span></a></li>
            ))}
          </ul>
        </div>
        <div class="ft__col">
          <h2 class="ft__h">Juridisch</h2>
          <ul role="list">
            {FOOTER_LINKS.legal.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
          </ul>
        </div>
      </nav>
    </div>

    <div class="ft__bottom">
      <p>© {year} {SITE.name} · Sinds {SITE.foundedYear}</p>
      <p class="ft__bottom-links">
        <a href="/privacyverklaring/">Privacy</a>
        <a href="/cookiebeleid/">Cookies</a>
        <a href="/algemene-voorwaarden/">Voorwaarden</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .ft { padding-block: clamp(3.5rem, 6vw, 6rem) 2rem; border-top: 3px solid var(--red); position: relative; }
  .ft__top { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  .ft__brand { max-width: 34rem; }
  .ft__claim { font-family: var(--font-display); text-transform: uppercase; font-size: clamp(1.3rem, 3.5vw, 1.9rem); line-height: 1; margin-top: 1.4rem; }
  .ft__contact { display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; margin-top: 1.4rem; color: var(--on-dark-soft); }
  .ft__contact a:hover { color: #fff; }
  .ft__phone { font-weight: 800; color: #fff !important; }
  .ft__social { display: flex; gap: 0.6rem; margin-top: 1.6rem; }
  .ft__soc { display: grid; place-items: center; width: 2.6rem; height: 2.6rem; border: 1px solid var(--line-dark); border-radius: var(--radius); color: var(--on-dark-soft); transition: all 0.2s var(--ease); }
  .ft__soc:hover { background: var(--red); border-color: var(--red); color: #fff; transform: translateY(-2px); }
  .ft__apps { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.6rem; }
  .ft__app { display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.55rem 1rem; border: 1px solid var(--line-dark); border-radius: var(--radius); transition: border-color 0.2s, background 0.2s; }
  .ft__app:hover { border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.04); }
  .ft__app span { display: flex; flex-direction: column; line-height: 1.05; font-weight: 800; font-size: 0.85rem; }
  .ft__app small { font-weight: 600; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--on-dark-soft); }

  .ft__cols { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2.5rem 1.5rem; }
  .ft__h { font-family: var(--font-sans); font-weight: 800; text-transform: uppercase; letter-spacing: 0.14em; font-size: 0.72rem; color: var(--red); margin-bottom: 1rem; }
  .ft__col ul { display: flex; flex-direction: column; gap: 0.6rem; }
  .ft__col a { color: var(--on-dark-soft); font-size: 0.92rem; }
  .ft__col a:hover { color: #fff; }
  .ft__city { color: var(--on-dark-faint); }

  .ft__bottom { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 1rem; margin-top: 3.5rem; padding-top: 1.5rem; border-top: 1px solid var(--line-dark); color: var(--on-dark-faint); font-size: 0.82rem; }
  .ft__bottom-links { display: flex; gap: 1.2rem; }
  .ft__bottom-links a:hover { color: #fff; }

  @media (min-width: 720px) { .ft__cols { grid-template-columns: repeat(4, 1fr); } }
  @media (min-width: 1000px) {
    .ft__top { grid-template-columns: 1.1fr 1.4fr; gap: 4rem; }
    .ft__cols { gap: 2.5rem; }
  }
</style>
