---
import { Image } from 'astro:assets';
import { photo } from '../lib/photos';
import BookTrialButton from './BookTrialButton.astro';
import { CONTACT } from '../consts';

interface Props {
  title?: string;
  sub?: string;
}
const {
  title = 'Klaar om de zwaartekracht te breken?',
  sub = 'Boek je gratis proefles en ervaar het zelf. Geen ervaring nodig, alleen zin om te bewegen.',
} = Astro.props;
---

<section class="cta noise">
  <Image
    src={photo('rooftop-silhouette.jpeg')}
    alt=""
    aria-hidden="true"
    widths={[800, 1300, 1920]}
    sizes="100vw"
    class="cta__bg"
  />
  <div class="cta__inner container reveal">
    <p class="eyebrow">Gratis &amp; vrijblijvend</p>
    <h2 class="cta__title">{title}</h2>
    <p class="cta__sub">{sub}</p>
    <div class="cta__actions">
      <BookTrialButton size="lg" />
      <a href={CONTACT.phoneHref} class="btn btn--ghost btn--lg">Bel {CONTACT.phone}</a>
    </div>
  </div>
</section>

<style>
  .cta { position: relative; padding-block: clamp(4rem, 9vw, 8rem); overflow: hidden; isolation: isolate; }
  .cta__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; }
  .cta::after {
    content: ""; position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(110deg, rgba(11,18,32,0.92) 30%, rgba(11,18,32,0.55) 75%, rgba(229,57,47,0.35));
  }
  .cta__inner { max-width: 46rem; }
  .cta__title { font-size: var(--fs-h2); line-height: 0.9; margin-top: 1rem; }
  .cta__sub { color: var(--on-dark-soft); font-size: var(--step-1); margin-top: 1.1rem; max-width: 38rem; }
  .cta__actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: 2rem; }
</style>
