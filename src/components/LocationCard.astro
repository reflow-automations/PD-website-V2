---
import { Image } from 'astro:assets';
import { photo } from '../lib/photos';
import { TYPE_LABEL, type Location } from '../data/locations';

interface Props {
  location: Location;
  href?: string;
}
const { location: loc, href = `/locaties/#${loc.slug}` } = Astro.props;
const badgeClass =
  loc.type === 'indoor' ? 'badge--indoor' : loc.type === 'outdoor' ? 'badge--outdoor' : 'badge--both';
---

<a href={href} class="loc reveal">
  <div class="loc__media">
    <Image
      src={photo(loc.photo)}
      alt={`Freerunning bij ${loc.name} in ${loc.city}`}
      widths={[360, 600, 760]}
      sizes="(max-width: 600px) 90vw, 360px"
      class="loc__img"
      style={`object-position:${loc.imgPos ?? 'center'}`}
    />
    <span class={`badge ${badgeClass} loc__badge`}>{TYPE_LABEL[loc.type]}</span>
  </div>
  <div class="loc__body">
    <p class="loc__city">{loc.city}</p>
    <h3 class="loc__name">{loc.name}</h3>
    <span class="loc__cta">
      Bekijk locatie
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="18" height="18"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
    </span>
  </div>
</a>

<style>
  .loc {
    display: flex; flex-direction: column; background: var(--panel);
    border: 1px solid var(--line-dark); border-radius: var(--radius); overflow: hidden;
    transition: transform 0.35s var(--ease), border-color 0.3s; position: relative;
  }
  .loc:hover { transform: translateY(-4px); border-color: rgba(255,255,255,0.28); }
  .loc__media { position: relative; aspect-ratio: 4 / 3; overflow: hidden; }
  .loc__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease); }
  .loc:hover .loc__img { transform: scale(1.06); }
  .loc__media::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(11,18,32,0.85), rgba(11,18,32,0.05) 55%);
  }
  .loc__badge { position: absolute; top: 0.8rem; left: 0.8rem; z-index: 1; background: rgba(11,18,32,0.6); backdrop-filter: blur(4px); }
  .loc__body { padding: 1.1rem 1.2rem 1.3rem; margin-top: -2.4rem; position: relative; z-index: 1; }
  .loc__city { font-weight: 800; text-transform: uppercase; letter-spacing: 0.14em; font-size: 0.68rem; color: var(--red); }
  .loc__name { font-size: clamp(1.35rem, 3vw, 1.7rem); margin-top: 0.3rem; line-height: 0.95; }
  .loc__cta {
    display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 0.9rem;
    font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.78rem;
    color: var(--on-dark-soft);
  }
  .loc__cta svg { transition: transform 0.3s var(--ease); }
  .loc:hover .loc__cta { color: #fff; }
  .loc:hover .loc__cta svg { transform: translateX(4px); color: var(--red); }
</style>
