---
import { allRooster, locations, DAGEN, AGE_FILTERS, ageKey, stripNieuw, LOCATION_COLORS, TYPE_LABEL } from '../data/locations';

const entries = allRooster
  .map((e) => ({ ...e, dag: stripNieuw(e.dag), age: ageKey(e.groep) }))
  .sort((a, b) => a.start.localeCompare(b.start));

const byDay = DAGEN.map((d) => ({
  day: d,
  items: entries.filter((e) => e.dag === d),
}));

const total = entries.length;
---

<div class="rooster" data-rooster data-total={total}>
  <div class="rooster__filters">
    <div class="fgroup">
      <span class="fgroup__label">Locatie</span>
      <div class="chips">
        <button class="chip is-active" data-filter="loc" data-value="">Alle</button>
        {locations.map((l) => (
          <button class="chip chip--loc" data-filter="loc" data-value={l.slug} style={`--c:${LOCATION_COLORS[l.slug]}`}>
            <span class="chip__dot"></span>
            <span class="chip__txt">
              <span class="chip__name">{l.name}</span>
              {!l.name.includes(l.city) && <span class="chip__city">{l.city}</span>}
            </span>
          </button>
        ))}
      </div>
    </div>

    <div class="fgroup">
      <span class="fgroup__label">Leeftijd</span>
      <div class="chips">
        <button class="chip is-active" data-filter="age" data-value="">Alle</button>
        {AGE_FILTERS.map((a) => (
          <button class="chip" data-filter="age" data-value={a.key}>{a.label}</button>
        ))}
      </div>
    </div>
  </div>

  <div class="rooster__bar">
    <p class="rooster__count"><b data-count>{total}</b> <span>lessen gevonden</span></p>
    <button class="rooster__reset" data-reset hidden>Wis filters ✕</button>
  </div>

  <div class="rooster__grid">
    {byDay.map((col) => (
      <section class="daycol" data-day={col.day}>
        <h3 class="daycol__h">{col.day}</h3>
        <div class="daycol__list">
          {col.items.map((it) => (
            <article class="cls" data-loc={it.locationSlug} data-age={it.age} data-dag={it.dag} style={`--c:${LOCATION_COLORS[it.locationSlug]}`}>
              <span class="cls__time">{it.start}<span class="cls__dash">-</span>{it.eind}</span>
              <span class="cls__group">
                {it.groep}
                {it.nieuw && <em class="cls__new">Nieuw</em>}
              </span>
              <a class="cls__loc" href={`/locaties/#${it.locationSlug}`}>
                <span class="dot"></span><b>{it.locationName}</b><em>{TYPE_LABEL[it.locationType]}</em>
              </a>
            </article>
          ))}
          <p class="daycol__empty" hidden>Geen lessen met deze filters.</p>
        </div>
      </section>
    ))}
  </div>

  <p class="rooster__none" data-none hidden>
    Geen lessen gevonden met deze combinatie. <button data-reset class="linklike">Wis de filters</button> en probeer opnieuw.
  </p>
</div>

<style>
  .rooster { --col-gap: 1rem; }
  .rooster__filters { display: flex; flex-direction: column; gap: 1.1rem; }
  .fgroup { display: grid; gap: 0.5rem; }
  .fgroup__label { font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.68rem; color: var(--on-dark-faint); }
  .chips { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .chip {
    font-weight: 700; font-size: 0.82rem; padding: 0.45rem 0.9rem; border-radius: 100px;
    border: 1px solid var(--line-dark); color: var(--on-dark-soft); background: var(--panel);
    transition: all 0.18s var(--ease); white-space: nowrap;
  }
  .chip:hover { border-color: rgba(255,255,255,0.4); color: #fff; }
  .chip.is-active { background: var(--red); border-color: var(--red); color: #fff; }
  .chip--loc { display: inline-flex; align-items: center; gap: 0.5rem; padding-block: 0.4rem; }
  .chip__dot { width: 0.55rem; height: 0.55rem; border-radius: 50%; background: var(--c); flex: none; }
  .chip__txt { display: flex; flex-direction: column; align-items: flex-start; line-height: 1.14; }
  .chip__city { font-size: 0.64rem; font-weight: 600; letter-spacing: 0.01em; color: var(--on-dark-faint); }
  .chip--loc:hover .chip__city { color: var(--on-dark-soft); }
  .chip--loc.is-active { background: var(--c); border-color: var(--c); color: #0B1220; }
  .chip--loc.is-active .chip__dot { background: rgba(11, 18, 32, 0.5); }
  .chip--loc.is-active .chip__city { color: rgba(11, 18, 32, 0.62); }

  .rooster__bar { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin: 1.6rem 0 1.2rem; padding-top: 1.2rem; border-top: 1px solid var(--line-dark); }
  .rooster__count b { font-family: var(--font-display); font-size: 1.5rem; color: var(--red); }
  .rooster__count span { color: var(--on-dark-soft); font-size: 0.9rem; }
  .rooster__reset, .linklike { color: var(--on-dark-soft); font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.76rem; }
  .rooster__reset:hover, .linklike:hover { color: var(--red); }
  .linklike { text-decoration: underline; }

  .rooster__grid { display: grid; gap: var(--col-gap); grid-template-columns: 1fr; }
  .daycol { background: var(--panel); border: 1px solid var(--line-dark); border-radius: var(--radius); padding: 0.9rem; }
  .daycol__h { font-size: 1.15rem; padding-bottom: 0.6rem; margin-bottom: 0.6rem; border-bottom: 2px solid var(--red); position: sticky; top: 5rem; background: var(--panel); }
  .daycol__list { display: flex; flex-direction: column; gap: 0.5rem; }
  .cls { display: grid; gap: 0.1rem; padding: 0.55rem 0.7rem; background: var(--ink); border: 1px solid var(--line-dark); border-radius: 3px; border-left: 3px solid var(--c, var(--red)); }
  .cls__time { font-family: var(--font-display); font-size: 0.95rem; letter-spacing: 0.03em; }
  .cls__dash { color: var(--on-dark-faint); margin: 0 0.45em; font-family: var(--font-sans); font-weight: 600; }
  .cls__group { font-size: 0.86rem; color: var(--on-dark); display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  .cls__new { font-style: normal; font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; background: var(--red); color: #fff; padding: 0.1rem 0.35rem; border-radius: 2px; }
  .cls__loc { display: inline-flex; align-items: center; gap: 0.38rem; font-size: 0.62rem; margin-top: 0.2rem; text-transform: uppercase; letter-spacing: 0.02em; }
  .cls__loc b { color: var(--c); font-weight: 800; }
  .cls__loc em { color: var(--on-dark-faint); font-style: normal; font-weight: 600; }
  .rooster.single-loc .cls__loc { display: none; }
  .cls__loc:hover b { filter: brightness(1.18); }
  .dot { width: 0.55rem; height: 0.55rem; border-radius: 50%; flex: none; background: var(--c); }
  .daycol__empty, .rooster__none { color: var(--on-dark-faint); font-size: 0.85rem; padding: 0.5rem 0; }
  .rooster__none { text-align: center; padding: 2rem 0; font-size: 1rem; }

  .daycol[hidden], .cls[hidden] { display: none; }

  @media (min-width: 560px) { .rooster__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .rooster__grid { grid-template-columns: repeat(4, 1fr); } }
  @media (min-width: 1200px) { .rooster__grid { grid-template-columns: repeat(7, 1fr); align-items: start; } .daycol { padding: 0.7rem; } }
</style>

<script>
  (() => {
    const root = document.querySelector('[data-rooster]') as HTMLElement | null;
    if (!root) return;
    // Locatie = multi-select, leeftijd = single-select. Leeg = "Alle". Tussen rijen = EN.
    const MULTI: Record<string, boolean> = { loc: true, age: false };
    const state: Record<string, Set<string>> = { loc: new Set(), age: new Set() };
    const chips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip'));
    const classes = Array.from(root.querySelectorAll<HTMLElement>('.cls'));
    const cols = Array.from(root.querySelectorAll<HTMLElement>('.daycol'));
    const countEl = root.querySelector('[data-count]');
    const resetBtn = root.querySelector<HTMLElement>('.rooster__reset');
    const noneEl = root.querySelector<HTMLElement>('[data-none]');

    function syncChips(filter: string) {
      const set = state[filter];
      chips
        .filter((ch) => ch.dataset.filter === filter)
        .forEach((ch) => {
          const v = ch.dataset.value!;
          ch.classList.toggle('is-active', v === '' ? set.size === 0 : set.has(v));
        });
    }

    function apply() {
      let visible = 0;
      classes.forEach((c) => {
        const ok =
          (state.loc.size === 0 || state.loc.has(c.dataset.loc!)) &&
          (state.age.size === 0 || state.age.has(c.dataset.age!));
        c.hidden = !ok;
        if (ok) visible++;
      });
      cols.forEach((col) => {
        const hasVisible = col.querySelector('.cls:not([hidden])');
        col.hidden = !hasVisible; // dagkolom verbergen als er geen lessen (meer) in zitten
        const empty = col.querySelector<HTMLElement>('.daycol__empty');
        if (empty) empty.hidden = !!hasVisible;
      });
      if (countEl) countEl.textContent = String(visible);
      root.classList.toggle('single-loc', state.loc.size === 1);
      const active = state.loc.size > 0 || state.age.size > 0;
      if (resetBtn) resetBtn.hidden = !active;
      if (noneEl) noneEl.hidden = visible !== 0;
    }

    function toggle(filter: string, value: string) {
      const set = state[filter];
      if (value === '') set.clear();              // "Alle" -> wis deze dimensie
      else if (set.has(value)) set.delete(value); // actieve nogmaals -> uit
      else { if (!MULTI[filter]) set.clear(); set.add(value); } // single-select: vervang
      syncChips(filter);
      apply();
    }

    chips.forEach((ch) =>
      ch.addEventListener('click', () => toggle(ch.dataset.filter!, ch.dataset.value!))
    );
    root.querySelectorAll('[data-reset]').forEach((b) =>
      b.addEventListener('click', () => {
        state.loc.clear(); state.age.clear();
        syncChips('loc'); syncChips('age');
        apply();
      })
    );

    // Pre-filter via ?locatie= (komma-lijst = meerdere) en ?leeftijd= (één)
    const params = new URLSearchParams(location.search);
    let preset = false;
    const presetDim = (param: string, filter: string) => {
      const raw = params.get(param);
      if (!raw) return;
      const vals = raw.split(',').filter((v) => chips.some((c) => c.dataset.filter === filter && c.dataset.value === v));
      (MULTI[filter] ? vals : vals.slice(0, 1)).forEach((v) => state[filter].add(v));
      if (vals.length) { preset = true; syncChips(filter); }
    };
    presetDim('locatie', 'loc');
    presetDim('leeftijd', 'age');
    apply();
    if (preset) root.scrollIntoView({ behavior: 'auto', block: 'start' });
  })();
</script>
