---
import { CHAT_WEBHOOK } from '../consts';
---

<div class="chat" data-chat data-endpoint={CHAT_WEBHOOK}>
  <!-- Launcher -->
  <button class="chat__launch" data-chat-toggle type="button" aria-label="Open de chat met Parkour Disciplines" aria-expanded="false">
    <svg class="chat__ico chat__ico--open" viewBox="0 0 24 24" fill="none" aria-hidden="true" width="26" height="26">
      <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3h11A2.5 2.5 0 0 1 20 5.5v8A2.5 2.5 0 0 1 17.5 16H9l-4 3.5V16H6.5A2.5 2.5 0 0 1 4 13.5v-8Z" fill="currentColor"></path>
      <circle cx="9" cy="9.5" r="1.1" fill="#0B1220"></circle>
      <circle cx="12.5" cy="9.5" r="1.1" fill="#0B1220"></circle>
      <circle cx="16" cy="9.5" r="1.1" fill="#0B1220"></circle>
    </svg>
    <svg class="chat__ico chat__ico--close" viewBox="0 0 24 24" fill="none" aria-hidden="true" width="22" height="22">
      <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"></path>
    </svg>
  </button>

  <!-- Panel -->
  <section class="chat__panel" data-chat-panel role="dialog" aria-label="Chat met Parkour Disciplines" aria-hidden="true">
    <header class="chat__head">
      <span class="chat__gear" aria-hidden="true"></span>
      <div class="chat__title">
        <strong>Vraag het PD</strong>
        <span>We reageren direct, 24/7</span>
      </div>
      <button class="chat__close" data-chat-toggle type="button" aria-label="Sluit de chat">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="20" height="20"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"></path></svg>
      </button>
    </header>

    <div class="chat__log" data-chat-log aria-live="polite"></div>

    <form class="chat__form" data-chat-form>
      <textarea data-chat-input rows="1" placeholder="Stel je vraag over lessen, locaties, prijzen..." aria-label="Jouw bericht"></textarea>
      <button type="submit" class="chat__send" aria-label="Verstuur">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="20" height="20"><path d="M4 12l16-7-7 16-2.5-6.5L4 12Z" fill="currentColor"></path></svg>
      </button>
    </form>
  </section>
</div>

<style>
  .chat { position: fixed; right: clamp(1rem, 3vw, 1.5rem); bottom: clamp(1rem, 3vw, 1.5rem); z-index: 200; }

  .chat__launch {
    width: 3.6rem; height: 3.6rem; border-radius: 50%; background: var(--red); color: #fff;
    display: grid; place-items: center; box-shadow: 0 14px 34px -10px rgba(229, 57, 47, 0.6);
    transition: transform 0.25s var(--ease), background 0.2s; position: relative;
  }
  .chat__launch::after {
    content: ""; position: absolute; inset: 0; border-radius: 50%; border: 2px solid var(--red);
    animation: chatPulse 2.6s var(--ease) infinite; pointer-events: none;
  }
  .chat__launch:hover { transform: translateY(-2px) scale(1.04); background: var(--red-600); }
  .chat__ico { transition: opacity 0.2s, transform 0.3s var(--ease); }
  .chat__ico--close { position: absolute; opacity: 0; transform: rotate(-45deg); }
  .chat.is-open .chat__ico--open { opacity: 0; transform: rotate(45deg); }
  .chat.is-open .chat__ico--close { opacity: 1; transform: rotate(0); }
  .chat.is-open .chat__launch::after { display: none; }
  @keyframes chatPulse { 0% { transform: scale(1); opacity: 0.7; } 70% { transform: scale(1.6); opacity: 0; } 100% { opacity: 0; } }

  .chat__panel {
    position: absolute; right: 0; bottom: 4.6rem;
    width: min(23rem, calc(100vw - 2rem)); height: min(34rem, calc(100dvh - 7rem));
    display: flex; flex-direction: column; overflow: hidden;
    background: var(--ink); border: 1px solid var(--line-dark); border-radius: 14px;
    box-shadow: var(--shadow-pop);
    opacity: 0; transform: translateY(12px) scale(0.98); transform-origin: bottom right;
    pointer-events: none; transition: opacity 0.28s var(--ease), transform 0.28s var(--ease-expo);
  }
  .chat.is-open .chat__panel { opacity: 1; transform: none; pointer-events: auto; }

  .chat__head { display: flex; align-items: center; gap: 0.7rem; padding: 0.9rem 1rem; background: var(--panel); border-bottom: 1px solid var(--line-dark); }
  .chat__gear { width: 2rem; height: 2rem; flex: none; background: var(--red); -webkit-mask: url('/brand/gear.png') center/contain no-repeat; mask: url('/brand/gear.png') center/contain no-repeat; }
  .chat__title { display: flex; flex-direction: column; line-height: 1.15; margin-right: auto; }
  .chat__title strong { font-family: var(--font-display); text-transform: uppercase; font-size: 1.05rem; letter-spacing: 0.02em; }
  .chat__title span { font-size: 0.7rem; color: var(--on-dark-soft); }
  .chat__close { color: var(--on-dark-soft); display: grid; place-items: center; width: 2rem; height: 2rem; border-radius: 6px; }
  .chat__close:hover { color: #fff; background: rgba(255,255,255,0.06); }

  .chat__log { flex: 1; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 0.6rem; scrollbar-width: thin; }
  /* .msg* styles staan in het global block hieronder (bubbels worden via JS aangemaakt) */

  .chat__form { display: flex; align-items: flex-end; gap: 0.5rem; padding: 0.7rem; border-top: 1px solid var(--line-dark); background: var(--panel); }
  .chat__form textarea {
    flex: 1; resize: none; max-height: 7rem; background: var(--ink); border: 1px solid var(--line-dark);
    border-radius: 10px; padding: 0.6rem 0.75rem; color: #fff; font-size: 0.9rem; line-height: 1.4;
  }
  .chat__form textarea:focus { outline: none; border-color: var(--red); }
  .chat__send { flex: none; width: 2.6rem; height: 2.6rem; border-radius: 10px; background: var(--red); color: #fff; display: grid; place-items: center; transition: background 0.2s, transform 0.2s; }
  .chat__send:hover { background: var(--red-600); transform: translateY(-1px); }
  .chat__send:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  @media (max-width: 480px) {
    .chat__panel { width: calc(100vw - 1.5rem); height: min(70dvh, calc(100dvh - 6rem)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .chat__launch::after { animation: none; }
  }
</style>

<style is:global>
  .chat .msg { max-width: 85%; padding: 0.65rem 0.85rem; border-radius: 12px; font-size: 0.9rem; line-height: 1.5; white-space: pre-wrap; word-wrap: break-word; }
  .chat .msg--bot { background: var(--panel-2); border: 1px solid var(--line-dark); align-self: flex-start; border-bottom-left-radius: 3px; color: var(--on-dark); }
  .chat .msg--bot a { color: #fff; font-weight: 700; text-decoration: underline; text-underline-offset: 2px; text-decoration-color: var(--red); }
  .chat .msg--bot a:hover { color: var(--red); }
  .chat .msg--user { background: var(--red); color: #fff; align-self: flex-end; border-bottom-right-radius: 3px; }
  .chat .msg--typing { display: inline-flex; gap: 4px; align-self: flex-start; }
  .chat .msg--typing span { width: 7px; height: 7px; border-radius: 50%; background: var(--on-dark-soft); animation: chatDot 1.2s infinite ease-in-out; }
  .chat .msg--typing span:nth-child(2) { animation-delay: 0.15s; }
  .chat .msg--typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes chatDot { 0%, 60%, 100% { transform: translateY(0); opacity: 0.5; } 30% { transform: translateY(-4px); opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .chat .msg--typing span { animation: none; } }
</style>

<script>
  (() => {
    const root = document.querySelector<HTMLElement>('[data-chat]');
    if (!root) return;
    const endpoint = root.dataset.endpoint || '';
    const panel = root.querySelector<HTMLElement>('[data-chat-panel]');
    const log = root.querySelector<HTMLElement>('[data-chat-log]');
    const form = root.querySelector<HTMLFormElement>('[data-chat-form]');
    const input = root.querySelector<HTMLTextAreaElement>('[data-chat-input]');
    const toggles = root.querySelectorAll<HTMLButtonElement>('[data-chat-toggle]');
    if (!panel || !log || !form || !input) return;

    const WELCOME =
      'Hoi! 👋 Ik ben de assistent van Parkour Disciplines. Vraag me gerust naar lessen, lestijden, locaties, prijzen of een gratis proefles.';

    // Session id (voor het geheugen in n8n) + zichtbare berichten (per tab).
    let sessionId = localStorage.getItem('pd-chat-session');
    if (!sessionId) {
      sessionId = 'web-' + Math.random().toString(36).slice(2) + Date.now().toString(36);
      localStorage.setItem('pd-chat-session', sessionId);
    }
    type Msg = { role: 'bot' | 'user'; text: string };
    let msgs: Msg[] = [];
    try { msgs = JSON.parse(sessionStorage.getItem('pd-chat-msgs') || '[]'); } catch {}
    if (!msgs.length) msgs = [{ role: 'bot', text: WELCOME }];

    const save = () => sessionStorage.setItem('pd-chat-msgs', JSON.stringify(msgs.slice(-40)));
    const scroll = () => { log.scrollTop = log.scrollHeight; };

    const escapeHtml = (s: string) =>
      s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] || c));
    // Maakt paden (/lesrooster), boekingslinks (x.trainin.app) en e-mails klikbaar.
    function linkify(raw: string) {
      const re = /(https?:\/\/[^\s<]+)|([a-z0-9-]+\.trainin\.app(?:\/[^\s<]*)?|(?:www\.)?freerunkleding\.nl(?:\/[^\s<]*)?)|(\/(?:lessen|lesrooster|locaties(?:\/#[a-z-]+)?|kinderfeestjes|zakelijk|over-ons|contact|faq))|([a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,})/gi;
      return escapeHtml(raw).replace(re, (m, url, dom, path, email) => {
        const ext = (href: string, text: string) => `<a href="${href}" target="_blank" rel="noopener">${text}</a>`;
        if (url) { const t = url.replace(/[.,)]+$/, ''); return ext(t, t) + url.slice(t.length); }
        if (dom) { const t = dom.replace(/[.,)]+$/, ''); return ext('https://' + t, t) + dom.slice(t.length); }
        if (path) return `<a href="${path}">${path}</a>`;
        if (email) return `<a href="mailto:${email}">${email}</a>`;
        return m;
      });
    }
    function bubble(m: Msg) {
      const el = document.createElement('div');
      el.className = 'msg msg--' + m.role;
      if (m.role === 'bot') el.innerHTML = linkify(m.text);
      else el.textContent = m.text;
      return el;
    }
    function render() {
      log.innerHTML = '';
      msgs.forEach((m) => log.appendChild(bubble(m)));
      scroll();
    }
    render();

    const setOpen = (open: boolean) => {
      root.classList.toggle('is-open', open);
      panel.setAttribute('aria-hidden', String(!open));
      toggles.forEach((t) => t.setAttribute('aria-expanded', String(open)));
      sessionStorage.setItem('pd-chat-open', open ? '1' : '0');
      if (open) { scroll(); setTimeout(() => input.focus(), 200); }
    };
    toggles.forEach((t) => t.addEventListener('click', () => setOpen(!root.classList.contains('is-open'))));
    if (sessionStorage.getItem('pd-chat-open') === '1') setOpen(true);

    // Auto-grow textarea
    const grow = () => { input.style.height = 'auto'; input.style.height = Math.min(input.scrollHeight, 112) + 'px'; };
    input.addEventListener('input', grow);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); form.requestSubmit(); }
    });

    let busy = false;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text || busy) return;
      busy = true;
      input.value = ''; grow();

      msgs.push({ role: 'user', text });
      log.appendChild(bubble({ role: 'user', text }));
      save(); scroll();

      const typing = document.createElement('div');
      typing.className = 'msg msg--bot msg--typing';
      typing.innerHTML = '<span></span><span></span><span></span>';
      log.appendChild(typing); scroll();

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: text, sessionId }),
        });
        const data = await res.json().catch(() => ({}));
        const reply = (data.reply || data.output || '').toString().trim()
          || 'Sorry, daar ging iets mis. Probeer het zo nog eens of mail info@parkourdisciplines.com.';
        typing.remove();
        msgs.push({ role: 'bot', text: reply });
        log.appendChild(bubble({ role: 'bot', text: reply }));
        save(); scroll();
      } catch {
        typing.remove();
        const text2 = 'Sorry, ik kan je nu even niet bereiken. Mail ons gerust op info@parkourdisciplines.com of bel 085 076 5270.';
        msgs.push({ role: 'bot', text: text2 });
        log.appendChild(bubble({ role: 'bot', text: text2 }));
        save(); scroll();
      } finally {
        busy = false;
        input.focus();
      }
    });
  })();
</script>
