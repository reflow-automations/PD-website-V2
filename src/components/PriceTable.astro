---
import type { Price } from '../data/locations';

interface Props {
  items: Price[];
  title?: string;
}
const { items, title } = Astro.props;
---

{items.length > 0 && (
  <div class="ptable">
    {title && <h4 class="ptable__title">{title}</h4>}
    <ul role="list">
      {items.map((p) => (
        <li class="ptable__row">
          <span class="ptable__label">
            {p.label}
            {p.url && (
              <a href={p.url} target="_blank" rel="noopener" class="ptable__book">boeken →</a>
            )}
          </span>
          <span class="ptable__price">
            {p.prijs}
            {p.periode && <small>{p.periode}</small>}
          </span>
        </li>
      ))}
    </ul>
  </div>
)}

<style>
  .ptable__title { font-family: var(--font-sans); font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.72rem; color: var(--red); margin-bottom: 0.7rem; }
  .ptable ul { display: flex; flex-direction: column; }
  .ptable__row {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    padding: 0.7rem 0; border-bottom: 1px solid var(--line-dark);
  }
  .ptable__row:last-child { border-bottom: 0; }
  .ptable__label { color: var(--on-dark); font-size: 0.92rem; display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem; }
  .ptable__book { color: var(--red); font-size: 0.74rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; }
  .ptable__book:hover { text-decoration: underline; }
  .ptable__price { font-family: var(--font-display); font-size: 1.1rem; white-space: nowrap; text-align: right; }
  .ptable__price small { display: block; font-family: var(--font-sans); font-weight: 600; font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--on-dark-faint); }
</style>
