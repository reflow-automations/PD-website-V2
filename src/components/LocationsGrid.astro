---
import LocationCard from './LocationCard.astro';
import { locations } from '../data/locations';

interface Props {
  limit?: number;
}
const { limit } = Astro.props;
const items = limit ? locations.slice(0, limit) : locations;
---

<div class="locgrid">
  {items.map((loc) => <LocationCard location={loc} />)}
</div>

<style>
  .locgrid {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 640px) { .locgrid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1100px) { .locgrid { grid-template-columns: repeat(3, 1fr); gap: 1.4rem; } }
</style>
