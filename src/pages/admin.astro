---
import BaseLayout from '../layouts/BaseLayout.astro';
import { locations } from '../data/locations';
---

<BaseLayout title="Beheer — galerij uploaden" noindex={true}>
  <section class="section section--ink">
    <div class="container-narrow">
      <p class="eyebrow">Beheer</p>
      <h1 class="h2">Galerij uploaden</h1>
      <p class="lead">Voeg foto's en video's toe aan de galerij. Ze verschijnen automatisch op de site (Cloudinary verwerkt ze, kan een paar minuten duren).</p>

      <form class="admin" data-admin>
        <label class="field">
          <span>Wachtwoord</span>
          <input type="password" name="password" autocomplete="current-password" required />
        </label>

        <div class="field">
          <span>Bestanden <em>(foto's en video's, meerdere tegelijk)</em></span>
          <label class="drop" data-drop>
            <input type="file" name="files" accept="image/*,video/*" multiple hidden data-fileinput />
            <svg viewBox="0 0 24 24" width="34" height="34" fill="none" aria-hidden="true"><path d="M12 16V4m0 0l-4 4m4-4l4 4M5 20h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <strong>Sleep bestanden hierheen</strong>
            <span>of klik om te kiezen</span>
          </label>
        </div>

        <div class="admin__row">
          <label class="field">
            <span>Locatie <em>(optioneel)</em></span>
            <select name="location" data-loc>
              <option value="">Geen / algemeen</option>
              {locations.map((l) => <option value={l.slug}>{l.name}</option>)}
            </select>
          </label>
          <label class="field">
            <span>Bijschrift <em>(optioneel, geldt voor deze upload)</em></span>
            <input type="text" name="caption" maxlength="140" placeholder="bv. Demo MBO Rijnland" data-cap />
          </label>
        </div>

        <div class="admin__foot">
          <button type="submit" class="btn btn--red btn--lg" data-submit>Uploaden
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </button>
          <a href="/galerij/" class="admin__link">Bekijk de galerij →</a>
        </div>
        <p class="admin__status" data-status></p>
      </form>

      <ul class="upl" data-list></ul>
    </div>
  </section>
</BaseLayout>

<style>
  .container-narrow { max-width: 680px; margin-inline: auto; padding-inline: var(--gutter); }
  .lead { color: var(--on-dark-soft); margin: 0.6rem 0 2rem; }
  .admin { display: grid; gap: 1.3rem; }
  .admin__row { display: grid; gap: 1.3rem; }
  @media (min-width: 640px) { .admin__row { grid-template-columns: 1fr 1.3fr; } }
  .field { display: grid; gap: 0.4rem; }
  .field > span { font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--on-dark-soft); }
  .field em { color: var(--on-dark-faint); font-style: normal; text-transform: none; letter-spacing: 0; font-weight: 500; }
  .field input, .field select {
    background: var(--ink); border: 1px solid var(--line-dark); border-radius: var(--radius);
    padding: 0.8rem 0.9rem; color: #fff; font-size: 0.95rem; transition: border-color 0.2s; width: 100%;
  }
  .field input:focus, .field select:focus { outline: none; border-color: var(--red); }

  .drop {
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem; text-align: center;
    padding: 2.2rem 1rem; border: 2px dashed var(--line-dark); border-radius: var(--radius);
    color: var(--on-dark-faint); cursor: pointer; transition: border-color 0.2s, background 0.2s;
  }
  .drop:hover, .drop.is-over { border-color: var(--red); background: rgba(229,57,47,0.05); color: var(--on-dark-soft); }
  .drop strong { color: #fff; font-size: 1.05rem; }
  .drop svg { color: var(--red); }

  .admin__foot { display: flex; flex-wrap: wrap; align-items: center; gap: 1.2rem; }
  .admin__link { color: var(--on-dark-soft); font-weight: 700; font-size: 0.85rem; }
  .admin__link:hover { color: var(--red); }
  .admin__status { font-size: 0.9rem; min-height: 1.2em; }
  .admin__status.is-err { color: #ff9a91; }
  .admin__status.is-ok { color: #8ee06a; }

  .upl { list-style: none; display: grid; gap: 0.5rem; margin-top: 1.6rem; }
  .upl li { display: flex; align-items: center; gap: 0.8rem; padding: 0.6rem 0.8rem; background: var(--panel); border: 1px solid var(--line-dark); border-radius: var(--radius); font-size: 0.88rem; }
  .upl__name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--on-dark); }
  .upl__badge { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; padding: 0.18rem 0.55rem; border-radius: 100px; white-space: nowrap; }
  .upl__badge.wait { background: var(--line-dark); color: var(--on-dark-soft); }
  .upl__badge.go { background: rgba(255,255,255,0.1); color: #fff; }
  .upl__badge.ok { background: rgba(74,222,128,0.18); color: #8ee06a; }
  .upl__badge.err { background: rgba(229,57,47,0.18); color: #ff9a91; }
  .upl__thumb { width: 38px; height: 38px; border-radius: 4px; object-fit: cover; flex: none; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-admin]')!;
  const drop = document.querySelector<HTMLElement>('[data-drop]')!;
  const fileInput = document.querySelector<HTMLInputElement>('[data-fileinput]')!;
  const locSel = document.querySelector<HTMLSelectElement>('[data-loc]')!;
  const capInput = document.querySelector<HTMLInputElement>('[data-cap]')!;
  const pwInput = form.querySelector<HTMLInputElement>('input[name="password"]')!;
  const statusEl = document.querySelector<HTMLElement>('[data-status]')!;
  const listEl = document.querySelector<HTMLUListElement>('[data-list]')!;
  const submitBtn = document.querySelector<HTMLButtonElement>('[data-submit]')!;
  let files: File[] = [];

  function setStatus(msg: string, cls = '') {
    statusEl.textContent = msg;
    statusEl.className = 'admin__status' + (cls ? ' ' + cls : '');
  }

  function renderList() {
    listEl.innerHTML = '';
    files.forEach((f, i) => {
      const li = document.createElement('li');
      li.dataset.i = String(i);
      li.innerHTML =
        `<span class="upl__name">${f.name}</span>` +
        `<span class="upl__badge wait" data-badge>wacht</span>`;
      listEl.appendChild(li);
    });
  }

  function addFiles(fl: FileList | File[]) {
    const incoming = [...fl].filter((f) => /^(image|video)\//.test(f.type));
    files = files.concat(incoming);
    renderList();
    if (files.length) setStatus(`${files.length} bestand(en) klaar om te uploaden.`);
  }

  fileInput.addEventListener('change', () => fileInput.files && addFiles(fileInput.files));
  ['dragenter', 'dragover'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('is-over'); })
  );
  ['dragleave', 'drop'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('is-over'); })
  );
  drop.addEventListener('drop', (e) => {
    const dt = (e as DragEvent).dataTransfer;
    if (dt?.files?.length) addFiles(dt.files);
  });

  function setBadge(i: number, text: string, cls: string) {
    const b = listEl.querySelector<HTMLElement>(`li[data-i="${i}"] [data-badge]`);
    if (b) { b.textContent = text; b.className = `upl__badge ${cls}`; }
  }

  async function uploadOne(file: File, i: number, sig: any) {
    setBadge(i, 'bezig', 'go');
    const fd = new FormData();
    fd.append('file', file);
    fd.append('api_key', sig.apiKey);
    fd.append('timestamp', String(sig.timestamp));
    fd.append('folder', sig.folder);
    fd.append('tags', sig.tags);
    if (sig.context) fd.append('context', sig.context);
    fd.append('signature', sig.signature);
    try {
      const r = await fetch(`https://api.cloudinary.com/v1_1/${sig.cloud}/auto/upload`, { method: 'POST', body: fd });
      const data = await r.json();
      if (!r.ok) throw new Error(data?.error?.message || 'upload mislukt');
      setBadge(i, 'klaar', 'ok');
      const li = listEl.querySelector(`li[data-i="${i}"]`);
      if (li && data.secure_url && /^image/.test(file.type)) {
        const img = document.createElement('img');
        img.className = 'upl__thumb';
        img.src = data.secure_url.replace('/upload/', '/upload/c_fill,w_76,h_76,q_auto/');
        li.prepend(img);
      }
      return true;
    } catch (err: any) {
      setBadge(i, 'fout', 'err');
      return false;
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!pwInput.value) { setStatus('Vul het wachtwoord in.', 'is-err'); return; }
    if (!files.length) { setStatus('Kies eerst bestanden.', 'is-err'); return; }

    submitBtn.disabled = true;
    setStatus('Bezig met ondertekenen…');
    let sig: any;
    try {
      const r = await fetch('/api/sign-upload', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pwInput.value, location: locSel.value, caption: capInput.value }),
      });
      if (r.status === 401) { setStatus('Onjuist wachtwoord.', 'is-err'); submitBtn.disabled = false; return; }
      if (r.status === 500) { setStatus('Server niet geconfigureerd: zet de env-vars in Vercel.', 'is-err'); submitBtn.disabled = false; return; }
      if (!r.ok) throw new Error('sign ' + r.status);
      sig = await r.json();
    } catch {
      setStatus('Kon de upload niet voorbereiden (staan de Vercel-functies live?).', 'is-err');
      submitBtn.disabled = false;
      return;
    }

    setStatus('Uploaden…');
    let ok = 0;
    for (let i = 0; i < files.length; i++) {
      const success = await uploadOne(files[i], i, sig);
      if (success) ok++;
    }
    setStatus(`${ok}/${files.length} geüpload. Ze verschijnen binnen enkele minuten op de galerij.`, ok ? 'is-ok' : 'is-err');
    files = [];
    fileInput.value = '';
    submitBtn.disabled = false;
  });
</script>
