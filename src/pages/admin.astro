---
import BaseLayout from '../layouts/BaseLayout.astro';
import { locations } from '../data/locations';
import { CLOUDINARY } from '../consts';

const locOpts = locations.map((l) => ({ slug: l.slug, name: l.name }));
---

<BaseLayout title="Beheer — galerij uploaden" noindex={true}>
  <section class="section section--ink">
    <div class="container-narrow">
      <p class="eyebrow">Beheer</p>
      <h1 class="h2">Galerij uploaden</h1>
      <p class="lead">Voeg foto's en video's toe aan de galerij. Ze verschijnen automatisch op de site (Cloudinary verwerkt ze, kan een paar minuten duren).</p>

      <form class="admin" data-admin>
        <label class="field">
          <span>Wachtwoord</span>
          <input type="password" name="password" autocomplete="current-password" required />
        </label>
        <label class="remember">
          <input type="checkbox" data-remember />
          <span>Onthoud op dit apparaat <em>(vult het wachtwoord voortaan automatisch in)</em></span>
        </label>

        <div class="field">
          <span>Bestanden <em>(foto's en video's, meerdere tegelijk)</em></span>
          <label class="drop" data-drop>
            <input type="file" name="files" accept="image/*,video/*" multiple hidden data-fileinput />
            <svg viewBox="0 0 24 24" width="34" height="34" fill="none" aria-hidden="true"><path d="M12 16V4m0 0l-4 4m4-4l4 4M5 20h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <strong>Sleep bestanden hierheen</strong>
            <span>of klik om te kiezen</span>
          </label>
        </div>

        <div class="admin__row">
          <label class="field">
            <span>Locatie <em>(optioneel)</em></span>
            <select name="location" data-loc>
              <option value="">Geen / algemeen</option>
              {locations.map((l) => <option value={l.slug}>{l.name}</option>)}
            </select>
          </label>
          <label class="field">
            <span>Bijschrift <em>(optioneel, geldt voor deze upload)</em></span>
            <input type="text" name="caption" maxlength="140" placeholder="bv. Demo MBO Rijnland" data-cap />
          </label>
        </div>

        <div class="admin__foot">
          <button type="submit" class="btn btn--red btn--lg" data-submit>Uploaden
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </button>
          <a href="/galerij/" class="admin__link">Bekijk de galerij →</a>
        </div>
        <p class="admin__status" data-status></p>
      </form>

      <ul class="upl" data-list></ul>

      <div class="manage">
        <div class="manage__head">
          <h2 class="h3">Bestaande media beheren</h2>
          <button type="button" class="admin__link" data-refresh>Vernieuwen ⟳</button>
        </div>
        <p class="manage__hint">Pas een bijschrift of locatie aan (handig bij typefouten) of verwijder een item. Gebruikt het wachtwoord hierboven.</p>
        <div data-manage data-cloud={CLOUDINARY.cloud} data-locs={JSON.stringify(locOpts)}>
          <p class="manage__msg">Laden…</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .container-narrow { max-width: 680px; margin-inline: auto; padding-inline: var(--gutter); }
  .lead { color: var(--on-dark-soft); margin: 0.6rem 0 2rem; }
  .admin { display: grid; gap: 1.3rem; }
  .admin__row { display: grid; gap: 1.3rem; }
  @media (min-width: 640px) { .admin__row { grid-template-columns: 1fr 1.3fr; } }
  .field { display: grid; gap: 0.4rem; }
  .field > span { font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--on-dark-soft); }
  .field em { color: var(--on-dark-faint); font-style: normal; text-transform: none; letter-spacing: 0; font-weight: 500; }
  .field input, .field select {
    background: var(--ink); border: 1px solid var(--line-dark); border-radius: var(--radius);
    padding: 0.8rem 0.9rem; color: #fff; font-size: 0.95rem; transition: border-color 0.2s; width: 100%;
  }
  .field input:focus, .field select:focus { outline: none; border-color: var(--red); }
  .remember { display: flex; align-items: center; gap: 0.55rem; margin-top: -0.6rem; font-size: 0.85rem; color: var(--on-dark-soft); cursor: pointer; }
  .remember input { width: 1.05rem; height: 1.05rem; accent-color: var(--red); flex: none; }
  .remember em { color: var(--on-dark-faint); font-style: normal; }

  .drop {
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem; text-align: center;
    padding: 2.2rem 1rem; border: 2px dashed var(--line-dark); border-radius: var(--radius);
    color: var(--on-dark-faint); cursor: pointer; transition: border-color 0.2s, background 0.2s;
  }
  .drop:hover, .drop.is-over { border-color: var(--red); background: rgba(229,57,47,0.05); color: var(--on-dark-soft); }
  .drop strong { color: #fff; font-size: 1.05rem; }
  .drop svg { color: var(--red); }

  .admin__foot { display: flex; flex-wrap: wrap; align-items: center; gap: 1.2rem; }
  .admin__link { color: var(--on-dark-soft); font-weight: 700; font-size: 0.85rem; }
  .admin__link:hover { color: var(--red); }
  .admin__status { font-size: 0.9rem; min-height: 1.2em; }
  .admin__status.is-err { color: #ff9a91; }
  .admin__status.is-ok { color: #8ee06a; }

  .upl { list-style: none; display: grid; gap: 0.5rem; margin-top: 1.6rem; }

  .manage { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--line-dark); }
  .manage__head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
  .manage__hint { color: var(--on-dark-faint); font-size: 0.85rem; margin: 0.5rem 0 1.3rem; }
  .manage__msg { color: var(--on-dark-faint); font-size: 0.9rem; padding: 1rem 0; }
  /* .upl li/.upl__name/.upl__badge/.upl__thumb zijn JS-aangemaakt -> is:global hieronder. */
</style>

<style is:global>
  .upl li { display: flex; align-items: center; gap: 0.8rem; padding: 0.6rem 0.8rem; background: var(--panel); border: 1px solid var(--line-dark); border-radius: var(--radius); font-size: 0.88rem; }
  .upl .upl__name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--on-dark); }
  .upl .upl__badge { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; padding: 0.18rem 0.55rem; border-radius: 100px; white-space: nowrap; }
  .upl .upl__badge.wait { background: var(--line-dark); color: var(--on-dark-soft); }
  .upl .upl__badge.go { background: rgba(255,255,255,0.1); color: #fff; }
  .upl .upl__badge.ok { background: rgba(74,222,128,0.18); color: #8ee06a; }
  .upl .upl__badge.err { background: rgba(229,57,47,0.18); color: #ff9a91; }
  .upl .upl__thumb { width: 38px; height: 38px; border-radius: 4px; object-fit: cover; flex: none; }

  .manage .mrow { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 0.8rem; padding: 0.6rem; background: var(--panel); border: 1px solid var(--line-dark); border-radius: var(--radius); margin-bottom: 0.6rem; }
  .manage .mrow__thumb { width: 56px; height: 56px; border-radius: 4px; object-fit: cover; flex: none; background: var(--ink); }
  .manage .mrow__fields { display: grid; gap: 0.4rem; min-width: 0; }
  .manage .mrow__cap, .manage .mrow__loc { background: var(--ink); border: 1px solid var(--line-dark); border-radius: 4px; padding: 0.45rem 0.6rem; color: #fff; font-size: 0.85rem; width: 100%; }
  .manage .mrow__cap:focus, .manage .mrow__loc:focus { outline: none; border-color: var(--red); }
  .manage .mrow__btns { display: flex; flex-direction: column; gap: 0.4rem; }
  .manage .mrow__save { background: var(--red); color: #fff; font-weight: 800; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; padding: 0.42rem 0.7rem; border-radius: 100px; white-space: nowrap; cursor: pointer; }
  .manage .mrow__del { background: rgba(255,255,255,0.06); color: var(--on-dark-soft); border: 1px solid var(--line-dark); border-radius: 100px; padding: 0.3rem 0.6rem; font-size: 0.85rem; cursor: pointer; }
  .manage .mrow__del:hover { color: #ff9a91; border-color: #ff9a91; }
  .manage .mrow__status { grid-column: 1 / -1; font-size: 0.75rem; color: var(--on-dark-faint); }
  .manage .mrow__status:empty { display: none; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-admin]')!;
  const drop = document.querySelector<HTMLElement>('[data-drop]')!;
  const fileInput = document.querySelector<HTMLInputElement>('[data-fileinput]')!;
  const locSel = document.querySelector<HTMLSelectElement>('[data-loc]')!;
  const capInput = document.querySelector<HTMLInputElement>('[data-cap]')!;
  const pwInput = form.querySelector<HTMLInputElement>('input[name="password"]')!;
  const statusEl = document.querySelector<HTMLElement>('[data-status]')!;
  const listEl = document.querySelector<HTMLUListElement>('[data-list]')!;
  const submitBtn = document.querySelector<HTMLButtonElement>('[data-submit]')!;
  const rememberBox = document.querySelector<HTMLInputElement>('[data-remember]')!;
  let files: File[] = [];

  // Onthoud-wachtwoord (opt-in, alleen op dit apparaat, in localStorage).
  const PW_KEY = 'pd_admin_pw';
  try {
    const saved = localStorage.getItem(PW_KEY);
    if (saved) { pwInput.value = saved; rememberBox.checked = true; }
  } catch (e) { /* localStorage geblokkeerd */ }

  function setStatus(msg: string, cls = '') {
    statusEl.textContent = msg;
    statusEl.className = 'admin__status' + (cls ? ' ' + cls : '');
  }

  function renderList() {
    listEl.innerHTML = '';
    files.forEach((f, i) => {
      const li = document.createElement('li');
      li.dataset.i = String(i);
      li.innerHTML =
        `<span class="upl__name">${f.name}</span>` +
        `<span class="upl__badge wait" data-badge>wacht</span>`;
      listEl.appendChild(li);
    });
  }

  function addFiles(fl: FileList | File[]) {
    const incoming = [...fl].filter((f) => /^(image|video)\//.test(f.type));
    files = files.concat(incoming);
    renderList();
    if (files.length) setStatus(`${files.length} bestand(en) klaar om te uploaden.`);
  }

  fileInput.addEventListener('change', () => fileInput.files && addFiles(fileInput.files));
  ['dragenter', 'dragover'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('is-over'); })
  );
  ['dragleave', 'drop'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('is-over'); })
  );
  drop.addEventListener('drop', (e) => {
    const dt = (e as DragEvent).dataTransfer;
    if (dt?.files?.length) addFiles(dt.files);
  });

  function setBadge(i: number, text: string, cls: string) {
    const b = listEl.querySelector<HTMLElement>(`li[data-i="${i}"] [data-badge]`);
    if (b) { b.textContent = text; b.className = `upl__badge ${cls}`; }
  }

  async function uploadOne(file: File, i: number, sig: any) {
    setBadge(i, 'bezig', 'go');
    const fd = new FormData();
    fd.append('file', file);
    fd.append('api_key', sig.apiKey);
    fd.append('timestamp', String(sig.timestamp));
    fd.append('folder', sig.folder);
    fd.append('tags', sig.tags);
    if (sig.context) fd.append('context', sig.context);
    fd.append('signature', sig.signature);
    try {
      const r = await fetch(`https://api.cloudinary.com/v1_1/${sig.cloud}/auto/upload`, { method: 'POST', body: fd });
      const data = await r.json();
      if (!r.ok) throw new Error(data?.error?.message || 'upload mislukt');
      setBadge(i, 'klaar', 'ok');
      const li = listEl.querySelector(`li[data-i="${i}"]`);
      if (li && data.secure_url && /^image/.test(file.type)) {
        const img = document.createElement('img');
        img.className = 'upl__thumb';
        img.src = data.secure_url.replace('/upload/', '/upload/c_fill,w_76,h_76,q_auto/');
        li.prepend(img);
      }
      return true;
    } catch (err: any) {
      setBadge(i, 'fout', 'err');
      return false;
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!pwInput.value) { setStatus('Vul het wachtwoord in.', 'is-err'); return; }
    if (!files.length) { setStatus('Kies eerst bestanden.', 'is-err'); return; }

    submitBtn.disabled = true;
    setStatus('Bezig met ondertekenen…');
    let sig: any;
    try {
      const r = await fetch('/api/sign-upload', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pwInput.value, location: locSel.value, caption: capInput.value }),
      });
      if (r.status === 401) { setStatus('Onjuist wachtwoord.', 'is-err'); submitBtn.disabled = false; return; }
      if (r.status === 500) { setStatus('Server niet geconfigureerd: zet de env-vars in Vercel.', 'is-err'); submitBtn.disabled = false; return; }
      if (!r.ok) throw new Error('sign ' + r.status);
      sig = await r.json();
      // Wachtwoord klopt: onthouden of juist wissen op basis van het vinkje.
      try {
        if (rememberBox.checked) localStorage.setItem(PW_KEY, pwInput.value);
        else localStorage.removeItem(PW_KEY);
      } catch (e) { /* localStorage geblokkeerd */ }
    } catch {
      setStatus('Kon de upload niet voorbereiden (staan de Vercel-functies live?).', 'is-err');
      submitBtn.disabled = false;
      return;
    }

    setStatus('Uploaden…');
    let ok = 0;
    for (let i = 0; i < files.length; i++) {
      const success = await uploadOne(files[i], i, sig);
      if (success) ok++;
    }
    setStatus(`${ok}/${files.length} geüpload. Ze verschijnen binnen enkele minuten op de galerij.`, ok ? 'is-ok' : 'is-err');
    files = [];
    fileInput.value = '';
    submitBtn.disabled = false;
    loadManage();
  });

  // ---- Bestaande media beheren (bijschrift/locatie aanpassen, verwijderen) ----
  const manageEl = document.querySelector<HTMLElement>('[data-manage]')!;
  const LOCS = JSON.parse(manageEl.dataset.locs || '[]');
  const MCLOUD = manageEl.dataset.cloud || '';

  function mThumb(it: any) {
    const pid = encodeURI(it.publicId);
    if (it.type === 'video') return `https://res.cloudinary.com/${MCLOUD}/video/upload/so_0,c_fill,w_112,h_112,f_jpg,q_auto/v${it.version}/${pid}.jpg`;
    return `https://res.cloudinary.com/${MCLOUD}/image/upload/c_fill,w_112,h_112,f_auto,q_auto/v${it.version}/${pid}.${it.format}`;
  }
  function esc(s: any) { return String(s || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;'); }

  async function mAction(action: string, it: any, extra: Record<string, string>) {
    if (!pwInput.value) return 'vul het wachtwoord hierboven in';
    try {
      const r = await fetch('/api/manage', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pwInput.value, action, publicId: it.publicId, resourceType: it.type, ...extra }),
      });
      if (r.status === 401) return 'wachtwoord onjuist';
      if (!r.ok) return 'fout (' + r.status + ')';
      return true;
    } catch {
      return 'netwerkfout';
    }
  }

  function mRow(it: any) {
    const row = document.createElement('div');
    row.className = 'mrow';
    const opts = ['<option value="">Geen / algemeen</option>']
      .concat(LOCS.map((l: any) => `<option value="${l.slug}"${l.slug === it.location ? ' selected' : ''}>${esc(l.name)}</option>`))
      .join('');
    row.innerHTML =
      `<img class="mrow__thumb" src="${mThumb(it)}" alt="" loading="lazy" />` +
      `<div class="mrow__fields">` +
        `<input class="mrow__cap" type="text" maxlength="140" placeholder="Bijschrift…" value="${esc(it.caption)}" />` +
        `<select class="mrow__loc">${opts}</select>` +
      `</div>` +
      `<div class="mrow__btns">` +
        `<button type="button" class="mrow__save">Opslaan</button>` +
        `<button type="button" class="mrow__del" title="Verwijderen">✕</button>` +
      `</div>` +
      `<span class="mrow__status"></span>`;
    const st = row.querySelector<HTMLElement>('.mrow__status')!;
    row.querySelector('.mrow__save')!.addEventListener('click', async () => {
      st.textContent = 'Opslaan…';
      const ok = await mAction('update', it, {
        caption: (row.querySelector('.mrow__cap') as HTMLInputElement).value,
        location: (row.querySelector('.mrow__loc') as HTMLSelectElement).value,
      });
      st.textContent = ok === true ? 'Opgeslagen ✓ (galerij ververst binnen enkele minuten)' : String(ok);
    });
    row.querySelector('.mrow__del')!.addEventListener('click', async () => {
      if (!confirm('Deze media definitief verwijderen uit Cloudinary?')) return;
      st.textContent = 'Verwijderen…';
      const ok = await mAction('delete', it, {});
      if (ok === true) row.remove();
      else st.textContent = String(ok);
    });
    return row;
  }

  async function loadManage() {
    manageEl.innerHTML = '<p class="manage__msg">Laden…</p>';
    let items: any[] = [];
    try {
      const r = await fetch('/api/gallery?fresh=' + Date.now());
      const d = await r.json();
      if (d && d.configured === false) {
        manageEl.innerHTML = '<p class="manage__msg">Nog niet geconfigureerd: zet de env-vars in Vercel en deploy opnieuw.</p>';
        return;
      }
      items = (d && d.items) || [];
    } catch {
      manageEl.innerHTML = '<p class="manage__msg">Kon de media niet laden (staan de Vercel-functies live?).</p>';
      return;
    }
    if (!items.length) {
      manageEl.innerHTML = '<p class="manage__msg">Nog geen media in de galerij.</p>';
      return;
    }
    manageEl.innerHTML = '';
    items.forEach((it) => manageEl.appendChild(mRow(it)));
  }

  document.querySelector('[data-refresh]')?.addEventListener('click', loadManage);
  loadManage();
</script>
