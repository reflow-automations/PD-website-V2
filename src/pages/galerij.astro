---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import { CLOUDINARY } from '../consts';
import { locations, LOCATION_COLORS } from '../data/locations';

const locMap = Object.fromEntries(locations.map((l) => [l.slug, l.name]));
const locColors = LOCATION_COLORS;
---

<BaseLayout
  title="Galerij"
  description="Foto's en video's van Parkour Disciplines: trainingen, events en de crew, op al onze locaties. Bekijk de community in actie."
>
  <PageHero
    eyebrow="Galerij"
    title="De community in actie"
    intro="Foto's en video's van onze trainingen, events en de crew, verspreid over al onze locaties. Een indruk van wat freerunning bij Parkour Disciplines betekent."
  />

  <section class="section section--ink">
    <div class="container--wide">
      <!-- Filters -->
      <div class="g-bar" data-bar hidden>
        <div class="g-frow">
          <span class="g-flabel">Soort</span>
          <div class="g-chips" data-group="type">
            <button class="g-chip is-active" data-filter="type" data-value="">Alles</button>
            <button class="g-chip" data-filter="type" data-value="image" data-foto hidden>Foto's</button>
            <button class="g-chip" data-filter="type" data-value="video" data-video hidden>Video's</button>
          </div>
        </div>
        <div class="g-frow" data-locrow hidden>
          <span class="g-flabel">Locatie</span>
          <div class="g-chips" data-group="location">
            <button class="g-chip is-active" data-filter="location" data-value="">Alle</button>
          </div>
        </div>
        <div class="g-frow" data-yearrow hidden>
          <span class="g-flabel">Periode</span>
          <div class="g-chips" data-group="year">
            <button class="g-chip is-active" data-filter="year" data-value="">Alle</button>
          </div>
        </div>
        <div class="g-barfoot">
          <p class="g-count"><b data-count>0</b> <span>items</span></p>
          <button class="g-reset" data-reset hidden>Wis filters ✕</button>
        </div>
      </div>

      <!-- Laadstaat -->
      <div class="g-state" data-loading>
        <span class="g-spinner" aria-hidden="true"></span>
        <p>Galerij laden…</p>
      </div>

      <!-- Lege staat -->
      <div class="g-state" data-empty hidden>
        <svg viewBox="0 0 24 24" width="40" height="40" fill="none" aria-hidden="true"><path d="M3 16l5-5 4 4 3-3 6 6M3 5h18v14H3z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <p>De galerij wordt binnenkort gevuld met foto's en video's. Kom snel terug!</p>
      </div>

      <!-- Grid (client-side gevuld) -->
      <div class="g-grid" data-grid></div>
      <p class="g-none" data-none hidden>Geen resultaten met deze filters. <button class="g-linklike" data-reset>Wis de filters</button></p>
    </div>
  </section>

  <CtaBand title="Zelf ervaren wat je hier ziet?" sub="Boek een gratis proefles en sta zelf op de volgende foto." />

  <!-- Lightbox -->
  <div class="lb" data-lb hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label="Galerij weergave">
    <button class="lb__close" data-lb-close aria-label="Sluiten">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
    </button>
    <button class="lb__nav lb__prev" data-lb-prev aria-label="Vorige">
      <svg viewBox="0 0 24 24" width="30" height="30" fill="none" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="lb__stage" data-lb-stage></div>
    <button class="lb__nav lb__next" data-lb-next aria-label="Volgende">
      <svg viewBox="0 0 24 24" width="30" height="30" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <p class="lb__cap" data-lb-cap hidden></p>
  </div>
</BaseLayout>

<style>
  .g-bar { display: flex; flex-direction: column; gap: 1.1rem; margin-bottom: 1.8rem; }
  .g-frow { display: grid; gap: 0.5rem; }
  .g-flabel { font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.66rem; color: var(--on-dark-faint); }
  .g-chips { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .g-barfoot { display: flex; align-items: center; gap: 1rem; padding-top: 1rem; border-top: 1px solid var(--line-dark); }
  .g-count b { font-family: var(--font-display); font-size: 1.3rem; color: var(--red); }
  .g-count span { color: var(--on-dark-soft); font-size: 0.88rem; }
  .g-reset { margin-left: auto; color: var(--on-dark-soft); font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.74rem; }
  .g-reset:hover { color: var(--red); }
  .g-none { text-align: center; padding: 3rem 1rem; color: var(--on-dark-faint); font-size: 1rem; }
  .g-linklike { color: var(--on-dark-soft); text-decoration: underline; font-weight: 700; }
  .g-linklike:hover { color: var(--red); }

  /* Het hidden-attribuut moet winnen van de display:flex-regels hieronder
     (anders blijven loader/lege-staat/lightbox zichtbaar en blokkeert de lightbox kliks). */
  .g-bar[hidden], .g-state[hidden], .lb[hidden] { display: none !important; }

  .g-state { display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 4rem 1rem; text-align: center; color: var(--on-dark-faint); }
  .g-state svg { color: var(--on-dark-faint); opacity: 0.6; }
  .g-state p { max-width: 36ch; }
  .g-spinner { width: 34px; height: 34px; border-radius: 50%; border: 3px solid var(--line-dark); border-top-color: var(--red); animation: g-spin 0.8s linear infinite; }
  @keyframes g-spin { to { transform: rotate(360deg); } }

  /* Masonry via CSS-kolommen — behoudt de aspect-ratio van elke shot */
  .g-grid { columns: 1; column-gap: 0.9rem; }
  @media (min-width: 560px) { .g-grid { columns: 2; } }
  @media (min-width: 900px) { .g-grid { columns: 3; } }
  @media (min-width: 1300px) { .g-grid { columns: 4; } }

  /* .g-item / .g-play / .g-meta worden via JS aangemaakt -> styles staan in
     het <style is:global> blok onderaan (scoped styles raken JS-elementen niet). */

  /* Lightbox */
  .lb { position: fixed; inset: 0; z-index: 200; display: flex; align-items: center; justify-content: center; background: rgba(6,10,18,0.92); backdrop-filter: blur(6px); opacity: 0; transition: opacity 0.25s; }
  .lb.is-open { opacity: 1; }
  .lb__stage { max-width: min(94vw, 1300px); max-height: 86vh; display: flex; align-items: center; justify-content: center; }
  /* .lb__stage img/video zijn JS-aangemaakt -> styles in het is:global blok onderaan. */
  .lb__close { position: absolute; top: 1rem; right: 1rem; color: #fff; width: 3rem; height: 3rem; display: grid; place-items: center; border-radius: 50%; background: rgba(255,255,255,0.08); transition: background 0.2s; }
  .lb__close:hover { background: rgba(255,255,255,0.18); }
  .lb__nav { position: absolute; top: 50%; transform: translateY(-50%); color: #fff; width: 3.2rem; height: 3.2rem; display: grid; place-items: center; border-radius: 50%; background: rgba(255,255,255,0.08); transition: background 0.2s; }
  .lb__nav:hover { background: rgba(255,255,255,0.18); }
  .lb__prev { left: 1rem; }
  .lb__next { right: 1rem; }
  .lb__nav[hidden] { display: none; }
  .lb__cap { position: absolute; left: 0; right: 0; bottom: 0; padding: 1.1rem 1.4rem; text-align: center; color: #fff; font-size: 0.9rem; font-weight: 600; letter-spacing: 0.01em; background: linear-gradient(to top, rgba(6,10,18,0.85), transparent); pointer-events: none; }
  .lb__cap[hidden] { display: none; }
  @media (max-width: 600px) {
    .lb__nav { width: 2.6rem; height: 2.6rem; background: rgba(255,255,255,0.12); }
    .lb__prev { left: 0.4rem; } .lb__next { right: 0.4rem; }
  }
</style>

<!-- JS-aangemaakte elementen (tegels, play-overlay, lightbox-media) krijgen geen
     scoped styles; daarom hier globaal, genamespaced onder .g-grid / .lb. -->
<style is:global>
  /* Filterchips: locatie/periode-chips worden via JS aangemaakt -> globaal. */
  .g-bar .g-chip { font-weight: 700; font-size: 0.82rem; padding: 0.45rem 0.95rem; border-radius: 100px; border: 1px solid var(--line-dark); color: var(--on-dark-soft); background: var(--panel); transition: all 0.18s var(--ease); white-space: nowrap; cursor: pointer; }
  .g-bar .g-chip:hover { border-color: rgba(255,255,255,0.4); color: #fff; }
  .g-bar .g-chip.is-active { background: var(--red); border-color: var(--red); color: #fff; }
  .g-bar .g-chip--loc { display: inline-flex; align-items: center; gap: 0.45rem; }
  .g-bar .g-dot { width: 0.55rem; height: 0.55rem; border-radius: 50%; background: var(--c); flex: none; }
  .g-bar .g-chip--loc.is-active { background: var(--c); border-color: var(--c); color: #0B1220; }
  .g-bar .g-chip--loc.is-active .g-dot { background: rgba(11,18,32,0.5); }

  .g-grid .g-item {
    display: block; width: 100%; margin: 0 0 0.9rem; padding: 0;
    position: relative; overflow: hidden; border-radius: var(--radius);
    background: var(--panel); border: 1px solid var(--line-dark);
    break-inside: avoid; cursor: pointer; line-height: 0;
    transition: transform 0.25s var(--ease), border-color 0.25s, box-shadow 0.25s;
  }
  .g-grid .g-item:hover { transform: translateY(-3px); border-color: rgba(229,57,47,0.5); box-shadow: 0 18px 40px -24px rgba(0,0,0,0.9); }
  .g-grid .g-item:focus-visible { outline: 2px solid var(--red); outline-offset: 2px; }
  .g-grid .g-item img { width: 100%; height: auto; display: block; aspect-ratio: var(--ar, 4 / 3); object-fit: cover; }
  .g-grid .g-item.is-hidden { display: none; }
  .g-grid .g-play { position: absolute; inset: 0; display: grid; place-items: center; background: linear-gradient(to top, rgba(11,18,32,0.45), rgba(11,18,32,0.05)); pointer-events: none; }
  .g-grid .g-play span { width: 3.4rem; height: 3.4rem; border-radius: 50%; display: grid; place-items: center; background: rgba(229,57,47,0.92); box-shadow: 0 6px 20px -6px rgba(0,0,0,0.6); transition: transform 0.25s var(--ease); }
  .g-grid .g-item:hover .g-play span { transform: scale(1.08); }
  .g-grid .g-play svg { color: #fff; margin-left: 3px; }
  .g-grid .g-meta { position: absolute; left: 0; right: 0; bottom: 0; padding: 1.4rem 0.7rem 0.5rem; font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; color: #fff; line-height: 1.2; pointer-events: none; background: linear-gradient(to top, rgba(11,18,32,0.82), transparent); }
  .lb .lb__stage img, .lb .lb__stage video { max-width: 94vw; max-height: 86vh; width: auto; height: auto; border-radius: 6px; display: block; box-shadow: 0 30px 80px -30px #000; }
</style>

<script define:vars={{ cloud: CLOUDINARY.cloud, tag: CLOUDINARY.tag, locMap, locColors }}>
  const RES = `https://res.cloudinary.com/${cloud}`;
  const grid = document.querySelector('[data-grid]');
  const bar = document.querySelector('[data-bar]');
  const loadingEl = document.querySelector('[data-loading]');
  const emptyEl = document.querySelector('[data-empty]');
  const countEl = document.querySelector('[data-count]');
  const fotoChip = document.querySelector('[data-foto]');
  const videoChip = document.querySelector('[data-video]');
  const noneEl = document.querySelector('[data-none]');
  const resetBtn = document.querySelector('[data-reset]');
  let items = [];
  let visible = [];
  const state = { type: '', location: '', year: '' };
  let olderThreshold = 0; // jaargrens: items met jaar < deze waarde vallen onder "Ouder"

  const tx = (type, t, it, ext) =>
    `${RES}/${type}/upload/${t}/v${it.version}/${encodeURI(it.publicId)}.${ext}`;
  const thumb = (it) =>
    it.type === 'video'
      ? tx('video', 'so_0,c_limit,w_700,f_jpg,q_auto', it, 'jpg')
      : tx('image', 'c_limit,w_700,f_auto,q_auto', it, it.format);
  const fullImg = (it) => tx('image', 'c_limit,w_1800,f_auto,q_auto', it, it.format);
  const videoSrc = (it) => tx('video', 'q_auto', it, 'mp4');

  function fmtDate(iso) {
    if (!iso) return '';
    try {
      const s = new Date(iso).toLocaleDateString('nl-NL', { month: 'long', year: 'numeric' });
      return s.charAt(0).toUpperCase() + s.slice(1);
    } catch (e) {
      return '';
    }
  }

  function yearOf(iso) {
    const m = iso ? String(iso).match(/^(\d{4})/) : null;
    return m ? m[1] : '';
  }

  // Primair: backend-functie (rijke metadata: locatie, datum, bijschrift).
  async function fetchFromApi() {
    try {
      const r = await fetch('/api/gallery');
      if (!r.ok) return null;
      const d = await r.json();
      if (!d || d.configured === false) return null;
      return d.items || [];
    } catch (e) {
      return null;
    }
  }

  // Fallback: publieke list-endpoint (geen secret nodig, alleen basis + datum).
  async function listOne(type) {
    try {
      const r = await fetch(`${RES}/${type}/list/${tag}.json`, { mode: 'cors' });
      if (!r.ok) {
        console.warn(`[galerij] ${type}-lijst gaf HTTP ${r.status}. Zet env-vars in Vercel (dan gebruikt 'ie /api/gallery), of zet "Resource list" aan in Cloudinary + tag media met "${tag}".`);
        return [];
      }
      const data = await r.json();
      return (data.resources || []).map((res) => ({
        type,
        publicId: res.public_id,
        version: res.version,
        format: res.format,
        width: res.width || 4,
        height: res.height || 3,
        createdAt: res.created_at || null,
        location: null,
        caption: null,
      }));
    } catch (e) {
      return [];
    }
  }
  async function fetchFromList() {
    const [imgs, vids] = await Promise.all([listOne('image'), listOne('video')]);
    return [...imgs, ...vids];
  }

  function render() {
    grid.innerHTML = '';
    items.forEach((it, i) => {
      const btn = document.createElement('button');
      btn.className = 'g-item';
      btn.type = 'button';
      btn.dataset.type = it.type;
      btn.dataset.loc = it.location || '';
      btn.dataset.year = yearOf(it.createdAt) || '';
      btn.dataset.index = String(i);
      btn.style.setProperty('--ar', `${it.width} / ${it.height}`);
      btn.setAttribute('aria-label', it.type === 'video' ? 'Video afspelen' : 'Foto bekijken');
      const img = document.createElement('img');
      img.src = thumb(it);
      img.loading = 'lazy';
      img.alt = 'Parkour Disciplines galerij';
      btn.appendChild(img);
      if (it.type === 'video') {
        const play = document.createElement('span');
        play.className = 'g-play';
        play.innerHTML = '<span><svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg></span>';
        btn.appendChild(play);
      }
      const locName = it.location && locMap[it.location] ? locMap[it.location] : null;
      if (locName) {
        const meta = document.createElement('span');
        meta.className = 'g-meta';
        meta.textContent = locName;
        btn.appendChild(meta);
      }
      btn.addEventListener('click', () => openLb(i));
      grid.appendChild(btn);
    });
  }

  function apply() {
    visible = [];
    grid.querySelectorAll('.g-item').forEach((el) => {
      const ok =
        (!state.type || el.dataset.type === state.type) &&
        (!state.location || el.dataset.loc === state.location) &&
        (!state.year ||
          (state.year === 'older'
            ? Number(el.dataset.year) > 0 && Number(el.dataset.year) < olderThreshold
            : el.dataset.year === state.year));
      el.classList.toggle('is-hidden', !ok);
      if (ok) visible.push(Number(el.dataset.index));
    });
    countEl.textContent = String(visible.length);
    const active = !!(state.type || state.location || state.year);
    if (resetBtn) resetBtn.hidden = !active;
    if (noneEl) noneEl.hidden = visible.length !== 0;
  }

  function buildFilterChips() {
    // Locatie-chips: alleen locaties die echt voorkomen, met hun kleur.
    const locGroup = document.querySelector('[data-group="location"]');
    Object.keys(locMap)
      .filter((slug) => items.some((it) => it.location === slug))
      .forEach((slug) => {
        const b = document.createElement('button');
        b.className = 'g-chip g-chip--loc';
        b.dataset.filter = 'location';
        b.dataset.value = slug;
        b.style.setProperty('--c', locColors[slug] || 'var(--red)');
        b.innerHTML = `<span class="g-dot"></span>${locMap[slug]}`;
        locGroup.appendChild(b);
        document.querySelector('[data-locrow]').hidden = false;
      });

    // Periode-chips op uploaddatum, slim begrensd: de recentste jaren expliciet,
    // de rest gebundeld als "Ouder" — zodat het niet uitdijt over de jaren.
    const yearGroup = document.querySelector('[data-group="year"]');
    const RECENT = 3;
    const allYears = [...new Set(items.map((it) => yearOf(it.createdAt)).filter(Boolean))].sort((a, b) => Number(b) - Number(a));
    const shownYears = allYears.slice(0, RECENT);
    const hasOlder = allYears.length > RECENT;
    olderThreshold = hasOlder ? Number(shownYears[shownYears.length - 1]) : 0;
    const addYearChip = (value, label) => {
      const b = document.createElement('button');
      b.className = 'g-chip';
      b.dataset.filter = 'year';
      b.dataset.value = value;
      b.textContent = label;
      yearGroup.appendChild(b);
    };
    shownYears.forEach((y) => addYearChip(y, y));
    if (hasOlder) addYearChip('older', 'Ouder');
    if (allYears.length) document.querySelector('[data-yearrow]').hidden = false;
  }

  function resetFilters() {
    state.type = ''; state.location = ''; state.year = '';
    bar.querySelectorAll('.g-chip').forEach((c) => c.classList.toggle('is-active', c.dataset.value === ''));
    apply();
  }

  // ---- Lightbox ----
  const lb = document.querySelector('[data-lb]');
  const stage = document.querySelector('[data-lb-stage]');
  const prevBtn = document.querySelector('[data-lb-prev]');
  const nextBtn = document.querySelector('[data-lb-next]');
  let lbPos = 0; // index binnen `visible`

  function showAt(pos) {
    const n = visible.length;
    lbPos = (pos + n) % n;
    const it = items[visible[lbPos]];
    stage.innerHTML = '';
    if (it.type === 'video') {
      const v = document.createElement('video');
      v.src = videoSrc(it);
      v.controls = true; v.autoplay = true; v.playsInline = true; v.preload = 'metadata';
      stage.appendChild(v);
    } else {
      const img = document.createElement('img');
      img.src = fullImg(it); img.alt = 'Parkour Disciplines galerij';
      stage.appendChild(img);
    }
    const cap = document.querySelector('[data-lb-cap]');
    const parts = [];
    if (it.caption) parts.push(it.caption);
    if (it.location && locMap[it.location]) parts.push(locMap[it.location]);
    const d = fmtDate(it.createdAt);
    if (d) parts.push(d);
    cap.textContent = parts.join('  ·  ');
    cap.hidden = parts.length === 0;
    const multi = n > 1;
    prevBtn.hidden = !multi; nextBtn.hidden = !multi;
  }

  function openLb(itemIndex) {
    const pos = visible.indexOf(itemIndex);
    if (pos === -1) return;
    lb.hidden = false; lb.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => lb.classList.add('is-open'));
    document.body.style.overflow = 'hidden';
    showAt(pos);
  }
  function closeLb() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    stage.innerHTML = '';
    setTimeout(() => { lb.hidden = true; }, 250);
  }

  document.querySelector('[data-lb-close]').addEventListener('click', closeLb);
  prevBtn.addEventListener('click', () => showAt(lbPos - 1));
  nextBtn.addEventListener('click', () => showAt(lbPos + 1));
  lb.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });
  window.addEventListener('keydown', (e) => {
    if (lb.hidden) return;
    if (e.key === 'Escape') closeLb();
    else if (e.key === 'ArrowLeft' && visible.length > 1) showAt(lbPos - 1);
    else if (e.key === 'ArrowRight' && visible.length > 1) showAt(lbPos + 1);
  });

  // Filterchips: gedelegeerd, zodat ook dynamisch toegevoegde locatie/periode-chips werken.
  bar.addEventListener('click', (e) => {
    const chip = e.target.closest('.g-chip');
    if (!chip || !chip.dataset.filter) return;
    const dim = chip.dataset.filter;
    state[dim] = chip.dataset.value;
    bar.querySelectorAll(`.g-chip[data-filter="${dim}"]`).forEach((c) => c.classList.toggle('is-active', c === chip));
    apply();
  });
  document.querySelectorAll('[data-reset]').forEach((b) => b.addEventListener('click', resetFilters));

  // ---- Init ----
  (async () => {
    let list = await fetchFromApi();
    if (!list) list = await fetchFromList();
    items = (list || []).sort((a, b) => {
      const ta = a.createdAt ? Date.parse(a.createdAt) : (a.version || 0) * 1000;
      const tb = b.createdAt ? Date.parse(b.createdAt) : (b.version || 0) * 1000;
      return tb - ta; // nieuwste upload eerst (datum + tijd)
    });
    loadingEl.hidden = true;
    if (!items.length) { emptyEl.hidden = false; return; }
    render();
    bar.hidden = false;
    if (items.some((x) => x.type === 'image')) fotoChip.hidden = false;
    if (items.some((x) => x.type === 'video')) videoChip.hidden = false;
    buildFilterChips();
    apply();
  })();
</script>
